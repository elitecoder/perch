{
  "name": "@perch-dev/cli",
  "version": "0.1.5",
  "type": "module",
  "bin": {
    "perch": "dist/index.js"
  },
  "private": true,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "@slack/web-api": "^7.0.0",
    "chalk": "^5.3.0",
    "execa": "^9.3.0",
    "keytar": "^7.9.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@perch-dev/shared": "workspace:*",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
