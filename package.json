{
  "name": "perch",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "description": "Your Claude Code sessions, always within reach — from Slack, on any device",
  "bin": {
    "perch": "packages/cli/dist/index.js"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "lint": "pnpm -r run lint",
    "dev": "pnpm --filter daemon run dev",
    "setup": "pnpm --filter cli run start setup"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/elitecoder/perch.git"
  }
}
