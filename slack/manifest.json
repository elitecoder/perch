{
  "display_information": {
    "name": "Perch",
    "description": "Remote control your Claude sessions from Slack",
    "background_color": "#1a1a2e"
  },
  "features": {
    "assistant_view": {
      "assistant_description": "Watch and control Claude Code sessions",
      "suggested_prompts": []
    },
    "bot_user": {
      "display_name": "perch",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "chat:write",
        "channels:read",
        "groups:read",
        "channels:history",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "files:read",
        "files:write",
        "reactions:read",
        "reactions:write"
      ]
    },
    "pkce_enabled": false
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im",
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
